# Dockerfile de desarrollo para Frontend con hot-reload
FROM node:20-alpine

WORKDIR /app

# Instalar dependencias
COPY package*.json ./
RUN npm install

# Copiar código
COPY . .

# Exponer puerto de Vite
EXPOSE 3000

# Comando de desarrollo con hot-reload
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
